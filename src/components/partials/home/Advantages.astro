---
import Medal from '@/icons/first.svg'
import Factory from '@/icons/industry.svg'
import BadgeCheck from '@/icons/features.svg'
import KeyRound from '@/icons/key.svg'
import home from '@/data/home.json'

const iconMap = {
    medal: Medal,
    factory: Factory,
    badge: BadgeCheck,
    key: KeyRound,
} as const

type IconName = keyof typeof iconMap

const advantages = home.advantages.map((item) => ({
    ...item,
    Icon: iconMap[(item.icon as IconName)] ?? Medal,
}))
---

<section class="py-10 md:py-20 scroll-mt-10" id="advantages">
    <div class="container">
        <ul class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
            {
                advantages.map(({ title, description, Icon }) => (
                    <li class="mx-auto flex max-w-84 flex-col items-center text-center text-secondary">
                        <Icon class="size-11 mb-8" aria-hidden="true" />
                        <h2 class="mb-3 text-2xl font-heading leading-tight">{title}</h2>
                        <p class=" text-secondary/80">{description}</p>
                    </li>
                ))
            }
        </ul>
    </div>
</section>
