---
import { Image } from 'astro:assets'

import Button from '@/components/starwind/button/Button.astro'
import galleryImage from '@/assets/gallery/1.png'

const galleryItems = [
    { id: 1, alt: 'Гранитный мемориальный комплекс, общий план' },
    { id: 2, alt: 'Гранитный мемориальный комплекс, вид сверху' },
    { id: 3, alt: 'Гранитный мемориальный комплекс, правый ракурс' },
    { id: 4, alt: 'Гранитный мемориальный комплекс, фронтальный ракурс' },
    { id: 5, alt: 'Гранитный мемориальный комплекс, левый ракурс' },
]
---

<section class="py-10 sm:py-20">
    <div class="container">
        <h2 class="mb-10 text-center font-heading text-4xl md:text-5xl lg:text-6xl">Галерея работ</h2>

        <ul class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-12">
            {
                galleryItems.map(({ id, alt }, index) => {
                    const cardClass = index === 0 ? 'lg:col-span-6 lg:row-span-2' : 'lg:col-span-3'

                    return (
                        <li class={cardClass}>
                            <a href="#" class="group block h-full overflow-hidden rounded-2xl">
                                <Image src={galleryImage} alt={alt} class:list={['h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]', index === 0 ? 'aspect-16/11' : 'aspect-16/10']} />
                            </a>
                        </li>
                    )
                })
            }
        </ul>

        <div class="mt-8 flex justify-center sm:mt-10">
            <Button href="#" variant="primary" size="lg" class="shadow-lg shadow-primary/25"> Смотреть все фото </Button>
        </div>
    </div>
</section>
