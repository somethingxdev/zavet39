---
import type { CollectionEntry } from 'astro:content'
import types from '@/data/monuments/types.json'
import Layout from '@/layouts/Layout.astro'
import MonumentCard from '@/components/services/MonumentCard.astro'
import Pagination from '@/components/services/Pagination.astro'
import ServicesHero from '@/components/services/ServicesHero.astro'
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/starwind/select'

type ServiceItem = CollectionEntry<'monuments' | 'curbs' | 'complexes' | 'socles' | 'fences' | 'benches-and-tables' | 'crosses' | 'accessories'>

type TypeItem = {
    slug: string
    title: string
}

type Props = {
    title: string
    categorySlug: string
    page: {
        data: ServiceItem[]
        currentPage: number
        lastPage: number
    }
    availableTypes?: TypeItem[]
    selectedType?: string
}

const TYPE_LABELS = Object.fromEntries(types.map((type) => [type.slug, type.title]))
const { title, categorySlug, page, availableTypes = [], selectedType } = Astro.props

const customCrumbs = [{ text: 'Home', href: '/' }, { text: 'Услуги', href: '/services' }, { text: title }]
const items = page.data
const currentPage = page.currentPage
const lastPage = page.lastPage
const basePath = selectedType ? `/services/${categorySlug}/${selectedType}` : `/services/${categorySlug}`
---

<Layout>
    <ServicesHero crumbs={customCrumbs} title={title} description="Наша компания предоставляет полный спектр услуг по изготовлению, оформлениюи установке памятников из гранита, мрамора, мраморной крошки и других материалов." />

    <section class="py-12 md:py-16">
        <div class="container">
            {
                availableTypes.length > 0 && (
                    <div class="mb-10 flex items-center justify-end gap-4">
                        <Select id="type-filter" name="type-filter" class="w-50" defaultValue={selectedType ? `/services/${categorySlug}/${selectedType}` : `/services/${categorySlug}`}>
                            <SelectTrigger class="min-w-50">
                                <SelectValue placeholder="Все типы" />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectItem value={`/services/${categorySlug}`} href={`/services/${categorySlug}`}>
                                    Все типы
                                </SelectItem>
                                {availableTypes.map((type) => (
                                    <SelectItem value={`/services/${categorySlug}/${type.slug}`} href={`/services/${categorySlug}/${type.slug}`}>
                                        {type.title}
                                    </SelectItem>
                                ))}
                            </SelectContent>
                        </Select>
                    </div>
                )
            }

            {
                items.length ? (
                    <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
                        {items.map((item) => (
                            <MonumentCard item={item} categorySlug={categorySlug} typeLabel={item.data.type ? (TYPE_LABELS[item.data.type] ?? item.data.type) : ''} />
                        ))}
                    </div>
                ) : (
                    <p class="text-lg text-foreground/80">Для выбранного типа пока нет товаров.</p>
                )
            }

            <Pagination currentPage={currentPage} lastPage={lastPage} basePath={basePath} />
        </div>
    </section>
</Layout>
