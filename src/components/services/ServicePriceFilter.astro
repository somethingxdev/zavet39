---
import { Popover, PopoverContent, PopoverHeader, PopoverTitle, PopoverTrigger } from '@/components/starwind/popover'
import { Checkbox } from '@/components/starwind/checkbox'
import { SlidersHorizontal } from '@lucide/astro'
---

<Popover>
  <PopoverTrigger class="border-input text-secondary flex items-center justify-between gap-2 rounded-md border bg-white shadow-x h-10 px-5">
        Фильтры
      <SlidersHorizontal class="size-4" />
      <span data-filter-count class="hidden rounded-full bg-primary shrink-0 size-5 grid place-items-center text-xs leading-none text-primary-foreground"></span>
    </PopoverTrigger>
    <PopoverContent align="start" class="w-56">
        <PopoverHeader>
            <PopoverTitle>Цена</PopoverTitle>
        </PopoverHeader>
        <div class="flex flex-col gap-3 pt-1">
            <Checkbox id="price-0-20000" label="До 20 000 ₽" data-range="0-20000"  />
            <Checkbox id="price-20000-35000" label="20 000 – 35 000 ₽" data-range="20000-35000" />
            <Checkbox id="price-35000-50000" label="35 000 – 50 000 ₽" data-range="35000-50000"  />
            <Checkbox id="price-50000" label="Свыше 50 000 ₽" data-range="50000" />
        </div>
    </PopoverContent>
</Popover>

<script>
    function parseMinPrice(variantPricesJson: string): number | null {
        try {
            const prices: string[] = JSON.parse(variantPricesJson)
            const nums = prices.map((s) => parseInt(s.replace(/\D/g, ''), 10)).filter((n) => !isNaN(n))
            return nums.length ? Math.min(...nums) : null
        } catch {
            return null
        }
    }

    function cardMatchesRange(card: HTMLElement, range: string): boolean {
        const min = parseMinPrice(card.dataset.variantPrices ?? '[]')
        if (min === null) return false
        if (range === '0-20000') return min < 20000
        if (range === '20000-35000') return min >= 20000 && min < 35000
        if (range === '35000-50000') return min >= 35000 && min < 50000
        if (range === '50000') return min >= 50000
        return false
    }

    function applyFilter() {
        const checkboxes = Array.from(document.querySelectorAll<HTMLInputElement>('input[data-range]'))
        const activeRanges = checkboxes.filter((cb) => cb.checked).map((cb) => cb.dataset.range!)

        const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-service-card]'))
        let visible = 0
        cards.forEach((card) => {
            const show = activeRanges.length === 0 || activeRanges.some((range) => cardMatchesRange(card, range))
            card.style.display = show ? '' : 'none'
            if (show) visible++
        })

        const empty = document.querySelector<HTMLElement>('[data-price-empty]')
        if (empty) empty.style.display = visible === 0 ? '' : 'none'

        const pagination = document.querySelector<HTMLElement>('[data-pagination-nav]')
        if (pagination) pagination.style.display = activeRanges.length === 0 ? '' : 'none'

        const countEl = document.querySelector<HTMLElement>('[data-filter-count]')
        if (countEl) {
            countEl.textContent = activeRanges.length > 0 ? String(activeRanges.length) : ''
            countEl.classList.toggle('hidden', activeRanges.length === 0)
        }
    }

    document.querySelectorAll<HTMLInputElement>('input[data-range]').forEach((cb) => {
        cb.addEventListener('change', applyFilter)
    })
</script>
