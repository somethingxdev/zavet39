---
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import { Button } from '@/components/starwind/button'
import { Card, CardContent, CardFooter, CardHeader, CardTitle } from '@/components/starwind/card'

type Props = {
    item: CollectionEntry<'monuments' | 'curbs' | 'complexes' | 'socles' | 'fences' | 'benches-and-tables' | 'crosses' | 'accessories'>
    typeLabel?: string
    categorySlug: string
}

const { item, typeLabel, categorySlug } = Astro.props
const productHref = `/services/${categorySlug}/${item.id}`
---

<Card class="gap-5">
    <CardHeader class="px-0">
        <a href={productHref} class="group block w-full">
            <div class="relative h-50 sm:h-69 w-full overflow-hidden bg-muted">
                <Image width="335" height="600" src={item.data.image} alt={item.data.title} class="w-full max-h-70 object-contain transition-transform duration-300 group-hover:scale-[1.03]" />
                {typeLabel && <span class="absolute top-4 left-4 rounded bg-white px-3 py-2 text-secondary">{typeLabel}</span>}
            </div>
        </a>
    </CardHeader>

    <CardContent class="space-y-2">
        <CardTitle class="mb-4">
            <a href={productHref} class="transition-colors hover:text-primary">
                {item.data.title}
            </a>
        </CardTitle>
        <p>
            <span class="font-semibold">Материалы:</span>
            {item.data.materials}
        </p>
        <p>
            <span class="font-semibold">Размеры:</span>
            {item.data.dimensions}
        </p>
    </CardContent>

    <CardFooter>
        {
            item.data.price?.trim() ? (
                <p class="text-xl font-heading"> {item.data.price} ₽</p>
            ) : (
                <Button href="/contacts" variant="primary" size="md" class="w-full">
                    Узнать цену
                </Button>
            )
        }
    </CardFooter>
</Card>
