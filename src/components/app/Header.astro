---
import { Image } from 'astro:assets'
import { Menu } from '@lucide/astro'
import { Button } from '@/components/starwind/button'
import { Sheet, SheetContent, SheetTrigger } from '@/components/starwind/sheet'
import PagefindConfig from 'astro-pagefind/components/PagefindConfig.astro'
import MaxIcon from '@/icons/max.svg'
import TelegramIcon from '@/icons/telegram.svg'
import PhoneIcon from '@/icons/phone.svg'
import contacts from '@/data/contacts.json'
const phoneHref = contacts.phoneHref.startsWith('tel:') ? contacts.phoneHref : `tel:${contacts.phoneHref}`
const telegramUrl = contacts.telegramUrl ?? '#'
const maxUrl = contacts.maxUrl ?? '#'

const navItems = [
    { label: 'Памятники', href: '/services/monuments' },
    { label: 'Благоустройство', href: '/services/landscaping' },
    { label: 'Комплексы', href: '/services/complexes' },
    { label: 'Ограды', href: '/services/fences' },
    { label: 'Лавочки и столики', href: '/services/benches-and-tables' },
    { label: 'Кресты', href: '/services/crosses' },
    { label: 'Оформление памятника', href: '/services/monument-design' },
    { label: 'Аксессуары', href: '/services/accessories' },
    { label: 'Наши работы', href: '/works' },
    { label: 'Контакты', href: '/contacts' },
]

const normalizedPathname = Astro.url.pathname.replace(/\/+$/, '') || '/'
const isServicesListPage = normalizedPathname.startsWith('/services') && !Astro.params.slug
const isInnerPage = !['/', '/services'].includes(normalizedPathname) && !isServicesListPage
const isActiveNavItem = (href: string) => normalizedPathname === href || normalizedPathname.startsWith(`${href}/`)
---

<header class="fixed sm:absolute left-0 md:top-5 z-50 w-full transition-all" class:list={isInnerPage ? 'bg-secondary xl:bg-transparent' : ''} data-mobile-header-shell>
    <div class="container">
        <div class="flex justify-between items-center gap-4 py-4 sm:px-6 sm:py-5 rounded-2xl transition-all" class:list={isInnerPage ? 'xl:bg-secondary' : 'pb-5 xl:bg-black/30 xl:backdrop-blur-3xl'}>
            <div class="flex items-center gap-6 xl:gap-15">
                <a href="/" class="flex items-center gap-2">
                    <Image src={import('@/assets/logo.svg')} alt="Logo" class="size-12 w-auto" />
                    <div class="flex flex-col text-white">
                        <span class="uppercase tracking-wider text-2xl font-heading">Завет</span>
                        <span class="uppercase text-xs font-medium tracking-tight">Память о наших предках</span>
                    </div>
                </a>

                <div class="relative z-20 hidden xl:block w-[435px]">
                    <PagefindConfig instance="header-search" lang="ru" preload={true} />
                    <pagefind-searchbox
                        instance="header-search"
                        class="pagefind-header-search"
                        placeholder="Поиск товаров"
                        hide-shortcut
                        show-keyboard-hints="false"
                        max-results="6"
                    >
                    </pagefind-searchbox>
                </div>
            </div>

            <div class="hidden xl:flex items-center gap-4">
                <a href={maxUrl} class="hover:-translate-y-1 transition-transform"> <MaxIcon /> </a>
                <a href={telegramUrl} class="hover:-translate-y-1 transition-transform"> <TelegramIcon /> </a>
                <Button class="ml-2" href={phoneHref}> <PhoneIcon /> {contacts.phoneDisplay}</Button>
            </div>

            <div class="xl:hidden flex items-center gap-3">
                <div class="hidden md:flex items-center gap-3">
                    <a href={maxUrl} class="hover:-translate-y-1 transition-transform"> <MaxIcon class="size-10" /> </a>
                    <a href={telegramUrl} class="hover:-translate-y-1 transition-transform"> <TelegramIcon class="size-10" /> </a>
                    <Button class="ml-2" size="sm" href={phoneHref}> <PhoneIcon /> {contacts.phoneDisplay}</Button>
                </div>
                <Sheet>
                    <SheetTrigger class="inline-flex items-center justify-center rounded-full size-12 bg-white/10 text-white">
                        <Menu class="size-6" />
                        <span class="sr-only">Открыть меню</span>
                    </SheetTrigger>

                    <SheetContent side="right" class="bg-secondary text-white border-white/10 p-6">
                        <div class="flex flex-col gap-6 pt-6">
                            <div class="flex items-center gap-4">
                                <a href={maxUrl} class="hover:-translate-y-1 transition-transform"> <MaxIcon /> </a>
                                <a href={telegramUrl} class="hover:-translate-y-1 transition-transform"> <TelegramIcon /> </a>
                            </div>

                            <Button class="w-full justify-center" href={phoneHref}> <PhoneIcon /> {contacts.phoneDisplay}</Button>

                            <nav>
                                <ul class="flex flex-col gap-3 text-lg">
                                    {
                                        navItems.map((item) => {
                                            const isActive = isActiveNavItem(item.href)

                                            return (
                                            <li>
                                                <a href={item.href} aria-current={isActive ? 'page' : undefined} class:list={['transition-colors hover:text-primary', isActive ? 'text-primary' : 'text-white/90']}>
                                                    {item.label}
                                                </a>
                                            </li>
                                            )
                                        })
                                    }
                                </ul>
                            </nav>
                        </div>
                    </SheetContent>
                </Sheet>
            </div>
        </div>

        <nav class="hidden xl:block border-b-2 border-[#2719071A] py-4">
            <ul class="flex items-center justify-between gap-6">
                {
                    navItems.map((item) => {
                        const isActive = isActiveNavItem(item.href)
                        const inactiveClass = isInnerPage ? 'text-secondary link-underline link-underline-black' : 'text-white/90 hover:text-primary'

                        return (
                        <li class="transition-colors font-medium" class:list={isActive ? 'text-primary link-underline' : inactiveClass}>
                            <a href={item.href} aria-current={isActive ? 'page' : undefined}>{item.label}</a>
                        </li>
                        )
                    })
                }
            </ul>
        </nav>
    </div>
</header>

<script>
    const headerShell = document.querySelector('[data-mobile-header-shell]')
    const mobileMedia = window.matchMedia('(max-width: 1023px)')

    const updateHeaderOnScroll = () => {
        if (!headerShell) return

        if (!mobileMedia.matches) {
            headerShell.classList.remove('bg-black/75', 'backdrop-blur-xl', 'shadow-xl', 'shadow-black/30')
            return
        }

        const isScrolled = window.scrollY > 8
        headerShell.classList.toggle('bg-black/75', isScrolled)
        headerShell.classList.toggle('backdrop-blur-xl', isScrolled)
        headerShell.classList.toggle('shadow-xl', isScrolled)
        headerShell.classList.toggle('shadow-black/30', isScrolled)
    }

    updateHeaderOnScroll()
    window.addEventListener('scroll', updateHeaderOnScroll, { passive: true })
    mobileMedia.addEventListener('change', updateHeaderOnScroll)
</script>


<style is:global>
.pagefind-header-search {
    --pf-background: color-mix(in oklab, var(--color-white) 5%, transparent);
    --pf-border: transparent;
    --pf-border-focus: color-mix(in oklab, var(--color-white) 35%, transparent);
    --pf-border-radius: 12px;
    --pf-dropdown-z-index: 100;
    --pf-font: var(--font-base);
    --pf-hover: color-mix(in oklab, var(--color-primary) 12%, transparent);
    --pf-input-height: 56px;
    --pf-input-font-size: 16px;
    --pf-outline-focus: var(--color-primary);
    --pf-searchbox-dropdown-max-height: 360px;
    --pf-searchbox-max-width: 435px;
    --pf-shadow-md: 0 20px 50px rgb(0 0 0 / 0.2);
    --pf-text: var(--color-secondary);
    --pf-text-muted: rgb(255 255 255 / 0.8);
    --pf-text-secondary: color-mix(in oklab, var(--color-secondary) 72%, transparent);
}

.pagefind-header-search .pf-searchbox {
    max-width: none !important;
    position: relative;
    z-index: 100;
}

.pagefind-header-search .pf-searchbox-input {
    border: 0 !important;
    box-shadow: none !important;
    color: white !important;
    font-weight: 400 !important;
    padding-inline-start: 20px !important;
    padding-inline-end: 48px !important;
}

.pagefind-header-search .pf-searchbox-input::placeholder {
    color: rgb(255 255 255 / 0.8) !important;
}

.pagefind-header-search .pf-searchbox-input-wrapper::before {
    background-color: white !important;
    height: 20px !important;
    inset-inline-start: auto !important;
    inset-inline-end: 20px !important;
    top: 18px !important;
    width: 20px !important;
}

.pagefind-header-search .pf-searchbox-input:focus {
    background-color: white !important;
    color: var(--color-secondary) !important;
    padding-inline-end: 48px !important;
}

.pagefind-header-search .pf-searchbox-input:focus::placeholder {
    color: color-mix(in oklab, var(--color-secondary) 55%, transparent) !important;
}

.pagefind-header-search .pf-searchbox-input-wrapper:has(.pf-searchbox-input:focus)::before {
    background-color: var(--color-secondary) !important;
}

.pagefind-header-search .pf-searchbox.open .pf-searchbox-input {
    background-color: white !important;
    border-bottom-color: transparent !important;
    border-bottom-left-radius: var(--pf-border-radius) !important;
    border-bottom-right-radius: var(--pf-border-radius) !important;
}

.pagefind-header-search .pf-searchbox-dropdown {
    background-color: white !important;
    border: 0 !important;
    border-radius: var(--pf-border-radius) !important;
    box-shadow: var(--pf-shadow-md) !important;
    margin-top: 8px !important;
    overflow: hidden !important;
    z-index: 100 !important;
}

.pagefind-header-search .pf-searchbox-result-title,
.pagefind-header-search .pf-searchbox-result-excerpt,
.pagefind-header-search .pf-searchbox-empty,
.pagefind-header-search .pf-searchbox-loading {
    color: var(--color-secondary) !important;
}

.pagefind-header-search .pf-searchbox-result {
    color: var(--color-secondary) !important;
}
</style>
