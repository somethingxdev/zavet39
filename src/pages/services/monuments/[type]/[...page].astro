---
import { getCollection } from 'astro:content'
import types from '@/data/monuments/types.json'
import ServiceListPage from '@/components/services/ServiceListPage.astro'

const categorySlug = 'monuments'
const categoryTitle = 'Памятники'
const allItems = await getCollection('monuments')
const availableTypes = types.filter((type) => allItems.some((item) => item.data.type && item.data.type === type.slug))

export async function getStaticPaths({ paginate }) {
    const items = await getCollection('monuments')
    const categoryTypes = types.filter((type) => items.some((item) => item.data.type && item.data.type === type.slug))

    return categoryTypes.flatMap((type) => {
        const typeItems = items.filter((item) => item.data.type === type.slug)
        if (!typeItems.length) return []
        return paginate(typeItems, {
            pageSize: 12,
            params: { type: type.slug },
        })
    })
}

const { page } = Astro.props
if (!page) {
    throw new Error('Expected `page` in Astro.props for paginated route /services/monuments/[type]/[...page]')
}
const type = Astro.params.type ?? ''
---

<ServiceListPage title={categoryTitle} categorySlug={categorySlug} page={page} availableTypes={availableTypes} selectedType={type} />
