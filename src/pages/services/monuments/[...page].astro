---
import { getCollection } from 'astro:content'
import types from '@/data/monuments/types.json'
import ServiceListPage from '@/components/services/ServiceListPage.astro'

const categorySlug = 'monuments'
const categoryTitle = 'Памятники'

const allItems = await getCollection('monuments')
const availableTypes = types.filter((type) => allItems.some((item) => item.data.type && item.data.type === type.slug))

export async function getStaticPaths({ paginate }) {
    const items = await getCollection('monuments')
    if (!items.length) return []
    return paginate(items, { pageSize: 12 })
}

const { page } = Astro.props
if (!page) {
    throw new Error('Expected `page` in Astro.props for paginated route /services/monuments/[...page]')
}
---

<ServiceListPage title={categoryTitle} categorySlug={categorySlug} page={page} availableTypes={availableTypes} />
