---
import type { GetStaticPaths } from 'astro'
import { getCollection, type CollectionEntry } from 'astro:content'
import Layout from '@/layouts/Layout.astro'
import Pagination from '@/components/services/Pagination.astro'
import ServicesHero from '@/components/services/ServicesHero.astro'
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/starwind/select'
import { SERVICE_CATEGORIES, type ServiceCategorySlug, type ServiceCollectionName } from '@/data/service-categories'
import { getServiceTypesByCategory, type ServiceTypeItem } from '@/data/service-types'
import Card from '@/components/services/ServiceCard.astro'

type ServiceItem = CollectionEntry<ServiceCollectionName>

type RouteProps = {
    categorySlug: ServiceCategorySlug
    categoryTitle: string
    availableTypes: ServiceTypeItem[]
}

type PagePayload = {
    data: ServiceItem[]
    currentPage: number
    lastPage: number
}

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
    const paginatedPaths = await Promise.all(
        SERVICE_CATEGORIES.map(async (category) => {
            const items = await getCollection(category.collection)
            if (!items.length) return []

            const categoryTypes = getServiceTypesByCategory(category.slug)
            const availableTypes = category.hasTypeFilters ? categoryTypes.filter((type) => items.some((item) => item.data.type && item.data.type === type.slug)) : []

            return paginate(items, {
                pageSize: 12,
                params: { category: category.slug },
                props: {
                    categorySlug: category.slug,
                    categoryTitle: category.title,
                    availableTypes,
                } satisfies RouteProps,
            })
        }),
    )

    return paginatedPaths.flat()
}

const {
    page,
    categorySlug,
    categoryTitle,
    availableTypes = [],
} = Astro.props as {
    page: PagePayload
    categorySlug: ServiceCategorySlug
    categoryTitle: string
    availableTypes?: ServiceTypeItem[]
}

if (!page) {
    throw new Error('Expected `page` in Astro.props for paginated route /services/[category]/[...page]')
}

const customCrumbs = [{ text: 'Home', href: '/' }, { text: 'Услуги', href: '/services' }, { text: categoryTitle }]
const items = page.data
const currentPage = page.currentPage
const lastPage = page.lastPage
const basePath = `/services/${categorySlug}`
const categoryTypes = getServiceTypesByCategory(categorySlug)
const TYPE_LABELS = categoryTypes.reduce<Record<string, string>>((acc, type) => {
    acc[type.slug] = type.title
    return acc
}, {})
---

<Layout>
    <ServicesHero crumbs={customCrumbs} title={categoryTitle} description="Наша компания предоставляет полный спектр услуг по изготовлению, оформлениюи установке памятников из гранита, мрамора, мраморной крошки и других материалов." />

    <section class="py-12 md:py-16">
        <div class="container">
            {
                availableTypes.length > 0 && (
                    <div class="mb-10 flex items-center justify-end gap-4">
                        <Select id="type-filter" name="type-filter" class="w-50" defaultValue={`/services/${categorySlug}`}>
                            <SelectTrigger class="min-w-50">
                                <SelectValue placeholder="Все типы" />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectItem value={`/services/${categorySlug}`} href={`/services/${categorySlug}`}>
                                    Все типы
                                </SelectItem>
                                {availableTypes.map((type) => (
                                    <SelectItem value={`/services/${categorySlug}/${type.slug}`} href={`/services/${categorySlug}/${type.slug}`}>
                                        {type.title}
                                    </SelectItem>
                                ))}
                            </SelectContent>
                        </Select>
                    </div>
                )
            }

            {
                items.length ? (
                    <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
                        {items.map((item) => (
                            <Card item={item} categorySlug={categorySlug} typeLabel={item.data.type ? (TYPE_LABELS[item.data.type] ?? item.data.type) : ''} />
                        ))}
                    </div>
                ) : (
                    <p class="text-lg text-foreground/80">Для выбранного типа пока нет товаров.</p>
                )
            }

            <Pagination currentPage={currentPage} lastPage={lastPage} basePath={basePath} />
        </div>
    </section>
</Layout>
