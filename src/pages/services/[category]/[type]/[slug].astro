---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import { ArrowLeft, ArrowRight } from '@lucide/astro'

import categories from '@/data/monuments/category.json'
import types from '@/data/monuments/types.json'
import Layout from '@/layouts/Layout.astro'
import { Button } from '@/components/starwind/button'
import { Toaster } from '@/components/starwind/toast'
import OrderModal from '@/components/services/OrderModal.astro'
import { Breadcrumbs } from 'astro-breadcrumbs'
import 'astro-breadcrumbs/breadcrumbs.css'

const TYPE_LABELS = Object.fromEntries(types.map((typeItem) => [typeItem.slug, typeItem.title]))
const CATEGORY_LABELS = Object.fromEntries(categories.map((categoryItem) => [categoryItem.slug, categoryItem.title]))

const prettify = (value: string) => CATEGORY_LABELS[value] ?? value.replace(/[-_]/g, ' ').replace(/^./, (char) => char.toUpperCase())

export async function getStaticPaths() {
    const monuments = await getCollection('monuments')
    return monuments.map((item) => ({
        params: {
            category: item.data.category,
            type: item.data.type,
            slug: item.id,
        },
    }))
}

const monuments = await getCollection('monuments')
const { category = '', type = '', slug = '' } = Astro.params

const item = monuments.find((entry) => entry.id === slug && entry.data.category === category && entry.data.type === type)

const similarItems = monuments.filter((entry) => entry.id !== item.id && entry.data.category === item.data.category).slice(0, 10)

const currentTypeLabel = TYPE_LABELS[item.data.type] ?? item.data.type
const crumbs = [{ text: 'Главная', href: '/' }, { text: prettify(item.data.category), href: `/services/${item.data.category}` }, { text: item.data.title }]
---

<Layout>
    <div class="py-30 md:pt-50 md:pb-20">
        <div class="container">
            <div class="text-secondary border-t-2 border-[#2719071A] pt-6">
                <Breadcrumbs crumbs={crumbs}>
                    <svg slot="index" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <g clip-path="url(#clip0_81_360)">
                            <path
                                d="M18.3333 4.77V1.66666C18.3333 1.20666 17.9608 0.83333 17.5 0.83333C17.0392 0.83333 16.6667 1.20666 16.6667 1.66666V3.63833L12.3308 0.712496C10.915 -0.242504 9.085 -0.242504 7.66917 0.712496L1.83583 4.64916C0.686667 5.425 0 6.71583 0 8.10333V15.8333C0 18.1308 1.86917 20 4.16667 20H5.83333C6.29417 20 6.66667 19.6267 6.66667 19.1667V11.6667C6.66667 11.2075 7.04 10.8333 7.5 10.8333H12.5C12.96 10.8333 13.3333 11.2075 13.3333 11.6667V19.1667C13.3333 19.6267 13.7058 20 14.1667 20H15.8333C18.1308 20 20 18.1308 20 15.8333V8.10333C20 6.78583 19.38 5.555 18.3333 4.77Z"
                                fill="var(--color-secondary)"
                                fill-opacity="0.8"></path>
                        </g>
                        <defs>
                            <clipPath id="clip0_81_360">
                                <rect width="20" height="20" fill="var(--color-secondary)"></rect>
                            </clipPath>
                        </defs>
                    </svg>
                    <svg slot="separator" width="7" height="16" viewBox="0 0 7 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M-9.76622e-05 15.072L5.2799 -9.53674e-07H6.3199L1.0399 15.072H-9.76622e-05Z" fill="var(--color-secondary)" fill-opacity="0.6"></path>
                    </svg>
                </Breadcrumbs>
                <svg slot="separator" width="7" height="16" viewBox="0 0 7 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M-9.76622e-05 15.072L5.2799 -9.53674e-07H6.3199L1.0399 15.072H-9.76622e-05Z" fill="white" fill-opacity="0.6"></path>
                </svg>
            </div>
            <section class="pt-5 md:py-10">
                <div class="grid gap-5 lg:grid-cols-2 items-start">
                    <div class="overflow-hidden rounded-xl bg-white h-80 sm:h-125 py-5 sm:py-8">
                        <Image src={item.data.image} alt={item.data.title} width="420" height="428" class="lg:max-w-110 h-full mx-auto object-contain" />
                    </div>

                    <article class="rounded-xl bg-white p-6 md:p-10">
                        <p class="mb-4 text-base text-secondary/70">{currentTypeLabel}</p>
                        <h1 class="mb-6 font-heading text-4xl">{item.data.title}</h1>

                        <div class="mb-10 grid gap-5 border-y border-secondary/15 py-6 md:grid-cols-2">
                            <p>
                                <span class="mb-1 block text-secondary/60">Материал:</span>
                                {item.data.materials}
                            </p>
                            <p>
                                <span class="mb-1 block text-secondary/60">Размеры:</span>
                                {item.data.dimensions}
                            </p>
                        </div>

                        <div class="flex flex-col gap-4 md:flex-row md:items-center w-full">
                            <OrderModal productTitle={item.data.title} productPrice={item.data.price} />
                            <div class="border-l border-primary/60 pl-4 shrink-0">
                                <p class="text-sm text-secondary/60">Стоимость:</p>
                                <p class="font-heading text-2xl">{item.data.price?.trim() ? `${item.data.price} ₽` : 'по запросу'}</p>
                            </div>
                        </div>
                    </article>
                </div>
            </section>
            {
                similarItems.length > 0 && (
                    <section class="py-20">
                        <h2 class="mb-10 text-center font-heading text-4xl md:text-5xl lg:text-6xl">Похожие товары</h2>
                        <div class="embla" data-similar-embla>
                            <div class="embla__viewport mb-8 overflow-visible">
                                <div class="embla__container flex gap-5 touch-pan-y">
                                    {similarItems.map((similarItem) => (
                                        <article class="embla__slide overflow-hidden rounded-2xl bg-white">
                                            <a href={`/services/${similarItem.data.category}/${similarItem.data.type}/${similarItem.id}`} class="group block h-full">
                                                <div class="relative h-64 bg-muted">
                                                    <Image src={similarItem.data.image} alt={similarItem.data.title} width="430" height="260" class="h-full w-full object-contain transition-transform duration-300 group-hover:scale-[1.03]" />
                                                    <span class="absolute top-4 left-4 rounded bg-white px-3 py-1 text-sm text-secondary">{TYPE_LABELS[similarItem.data.type] ?? similarItem.data.type}</span>
                                                </div>

                                                <div class="p-5 space-y-2">
                                                    <h3 class="text-xl font-heading">{similarItem.data.title}</h3>
                                                    <p>
                                                        <span class="font-semibold">Материалы:</span>
                                                        {similarItem.data.materials}
                                                    </p>
                                                    <p>
                                                        <span class="font-semibold">Размеры:</span>
                                                        {similarItem.data.dimensions}
                                                    </p>
                                                    <p class="text-lg text-secondary/85">{similarItem.data.price?.trim() ? `${similarItem.data.price} ₽` : 'Цена по запросу'}</p>
                                                </div>
                                            </a>
                                        </article>
                                    ))}
                                </div>
                            </div>

                            <div class="flex items-center justify-center gap-5">
                                <Button variant="primary" size="icon-lg" class="embla__prev" aria-label="Предыдущий товар">
                                    <ArrowLeft />
                                </Button>
                                <Button variant="primary" size="icon-lg" class="embla__next" aria-label="Следующий товар">
                                    <ArrowRight />
                                </Button>
                            </div>
                        </div>
                    </section>
                )
            }
        </div>
    </div>
</Layout>

<script>
    import EmblaCarousel from 'embla-carousel'

    const wrapperNode = document.querySelector('[data-similar-embla]') as HTMLElement | null
    const viewportNode = wrapperNode?.querySelector('.embla__viewport') as HTMLElement | null
    const prevButtonNode = wrapperNode?.querySelector('.embla__prev') as HTMLButtonElement | null
    const nextButtonNode = wrapperNode?.querySelector('.embla__next') as HTMLButtonElement | null

    if (viewportNode && prevButtonNode && nextButtonNode) {
        const emblaApi = EmblaCarousel(viewportNode, { loop: false, align: 'start', containScroll: 'trimSnaps' })

        prevButtonNode.addEventListener('click', () => emblaApi.goToPrev(), false)
        nextButtonNode.addEventListener('click', () => emblaApi.goToNext(), false)

        const toggleButtonsDisabled = (api: typeof emblaApi) => {
            prevButtonNode.toggleAttribute('disabled', !api.canGoToPrev())
            nextButtonNode.toggleAttribute('disabled', !api.canGoToNext())
        }

        toggleButtonsDisabled(emblaApi)
        emblaApi.on('select', toggleButtonsDisabled)
        emblaApi.on('reinit', toggleButtonsDisabled)
    }
</script>

<style>
    .embla__slide {
        flex: 0 0 23.5%;
        min-width: 0;
    }

    @media (max-width: 1100px) {
        .embla__slide {
            flex: 0 0 48%;
        }
    }

    @media (max-width: 760px) {
        .embla__slide {
            flex: 0 0 80%;
        }
    }
</style>
