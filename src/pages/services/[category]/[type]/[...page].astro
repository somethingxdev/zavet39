---
import { getCollection } from 'astro:content'
import categories from '@/data/monuments/category.json'
import types from '@/data/monuments/types.json'

import Layout from '@/layouts/Layout.astro'
import MonumentCard from '@/components/services/MonumentCard.astro'
import Pagination from '@/components/services/Pagination.astro'
import ServicesHero from '@/components/services/ServicesHero.astro'
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/starwind/select'

const TYPE_LABELS = Object.fromEntries(types.map((type) => [type.slug, type.title]))

const CATEGORY_LABELS = Object.fromEntries(categories.map((category) => [category.slug, category.title]))

const prettify = (value: string) => CATEGORY_LABELS[value] ?? value.replace(/[-_]/g, ' ').replace(/^./, (char) => char.toUpperCase())

export async function getStaticPaths({ paginate }) {
    const monuments = await getCollection('monuments')
    return categories.flatMap(({ slug }) => {
        const categoryItems = monuments.filter((item) => item.data.category === slug)
        const availableTypes = types.filter((type) => categoryItems.some((item) => item.data.type === type.slug))

        return availableTypes.flatMap((type) => {
            const typeSlug = type.slug
            const typeItems = categoryItems.filter((item) => item.data.type === typeSlug)
            if (!typeItems.length) return []

            return paginate(typeItems, {
                pageSize: 12,
                params: { category: slug, type: typeSlug },
                props: { category: slug, type: typeSlug },
            })
        })
    })
}

const monuments = await getCollection('monuments')
const category = Astro.props.category ?? Astro.params.category ?? ''
const type = Astro.props.type ?? Astro.params.type ?? ''

const categoryItems = monuments.filter((item) => item.data.category === category)
const availableTypes = types.filter((typeItem) => categoryItems.some((item) => item.data.type === typeItem.slug))
const { page } = Astro.props

const items = page.data
const currentPage = page.currentPage
const lastPage = page.lastPage

const customCrumbs = [{ text: 'Home', href: '/' }, { text: 'Услуги', href: '/services' }, { text: prettify(category) }]
---

<Layout>
    <ServicesHero crumbs={customCrumbs} title={prettify(category)} description="Наша компания предоставляет полный спектр услуг по изготовлению, оформлениюи установке памятников из гранита, мрамора, мраморной крошки и других материалов." />

    <section class="py-12 md:py-16">
        <div class="container">
            <div class="mb-6 flex items-center gap-4">
                <Select id="type-filter" name="type-filter" class="w-50" defaultValue={`/services/${category}/${type}`}>
                    <SelectTrigger class="min-w-50">
                        <SelectValue placeholder="Все типы" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectItem value={`/services/${category}`} href={`/services/${category}`}>Все типы</SelectItem>
                        {
                            availableTypes.map((typeItem) => (
                                <SelectItem value={`/services/${category}/${typeItem.slug}`} href={`/services/${category}/${typeItem.slug}`}>
                                    {typeItem.title}
                                </SelectItem>
                            ))
                        }
                    </SelectContent>
                </Select>
            </div>

            {
                items.length ? (
                    <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
                        {items.map((item) => (
                            <MonumentCard item={item} typeLabel={TYPE_LABELS[item.data.type] ?? item.data.type} />
                        ))}
                    </div>
                ) : (
                    <p class="text-lg text-foreground/80">Для выбранного типа пока нет памятников.</p>
                )
            }

            <Pagination currentPage={currentPage} lastPage={lastPage} basePath={`/services/${category}/${type}`} />
        </div>
    </section>
</Layout>
