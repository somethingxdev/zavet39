---
import { getCollection } from 'astro:content'
import ServiceDetailPage from '@/components/services/ServiceDetailPage.astro'

const categorySlug = 'accessories'
const categoryTitle = 'Аксессуары'

export async function getStaticPaths() {
    const items = await getCollection('accessories')
    return items.map((item) => ({
        params: { slug: item.id },
    }))
}

const items = await getCollection('accessories')
const slug = Astro.params.slug ?? ''
const item = items.find((entry) => entry.id === slug)
if (!item) {
    throw new Error(`Item not found for /services/accessories/${slug}`)
}
const similarItems = items.filter((entry) => entry.id !== item.id).slice(0, 10)
---

<ServiceDetailPage item={item} similarItems={similarItems} categorySlug={categorySlug} categoryTitle={categoryTitle} />
