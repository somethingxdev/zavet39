---
import { getCollection } from 'astro:content'
import ServiceListPage from '@/components/services/ServiceListPage.astro'

const categorySlug = 'fences'
const categoryTitle = 'Ограды'

export async function getStaticPaths({ paginate }) {
    const items = await getCollection('fences')
    if (!items.length) return []
    return paginate(items, { pageSize: 12 })
}

const { page } = Astro.props
if (!page) {
    throw new Error('Expected `page` in Astro.props for paginated route /services/fences/[...page]')
}
---

<ServiceListPage title={categoryTitle} categorySlug={categorySlug} page={page} />
