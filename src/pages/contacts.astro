---
import Layout from '@/layouts/Layout.astro'
import { Breadcrumbs } from 'astro-breadcrumbs'
import 'astro-breadcrumbs/breadcrumbs.css'
import contactsRaw from '@/data/contacts.json'
import { Card, CardContent, CardHeader, CardTitle } from '@/components/starwind/card'

import DecorImage from '@/icons/card-decor.svg'
type ContactsData = {
    pageTitle: string
    addressLabel: string
    address: string
    phoneLabel: string
    phoneDisplay: string
    phoneHref: string
    emailLabel: string
    email: string
}

const defaults: ContactsData = {
    pageTitle: 'Наши контакты',
    addressLabel: 'Наш адрес',
    address: 'г. Калининград, ул. Барнаульская, 5, 1 этаж',
    phoneLabel: 'Контактные номера',
    phoneDisplay: '+7 910 636 73 13',
    phoneHref: '+79106367313',
    emailLabel: 'Электронная почта',
    email: 'andrey.zav@mail.ru',
}

const contacts = { ...defaults, ...contactsRaw } as ContactsData
const crumbs = [{ text: 'Главная', href: '/' }, { text: 'Контакты' }]

const phoneHref = contacts.phoneHref.startsWith('tel:') ? contacts.phoneHref : `tel:${contacts.phoneHref}`
const emailHref = contacts.email.startsWith('mailto:') ? contacts.email : `mailto:${contacts.email}`
---

<Layout>
    <div class="bg-[#F6F6F6] py-30 md:pt-50 md:pb-20">
        <div class="container">
            <div class="text-secondary pt-6">
                <Breadcrumbs crumbs={crumbs}>
                    <svg slot="index" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <g clip-path="url(#clip0_81_360)">
                            <path
                                d="M18.3333 4.77V1.66666C18.3333 1.20666 17.9608 0.83333 17.5 0.83333C17.0392 0.83333 16.6667 1.20666 16.6667 1.66666V3.63833L12.3308 0.712496C10.915 -0.242504 9.085 -0.242504 7.66917 0.712496L1.83583 4.64916C0.686667 5.425 0 6.71583 0 8.10333V15.8333C0 18.1308 1.86917 20 4.16667 20H5.83333C6.29417 20 6.66667 19.6267 6.66667 19.1667V11.6667C6.66667 11.2075 7.04 10.8333 7.5 10.8333H12.5C12.96 10.8333 13.3333 11.2075 13.3333 11.6667V19.1667C13.3333 19.6267 13.7058 20 14.1667 20H15.8333C18.1308 20 20 18.1308 20 15.8333V8.10333C20 6.78583 19.38 5.555 18.3333 4.77Z"
                                fill="var(--color-secondary)"
                                fill-opacity="0.8"></path>
                        </g>
                        <defs>
                            <clipPath id="clip0_81_360">
                                <rect width="20" height="20" fill="var(--color-secondary)"></rect>
                            </clipPath>
                        </defs>
                    </svg>
                    <svg slot="separator" width="7" height="16" viewBox="0 0 7 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M-9.76622e-05 15.072L5.2799 -9.53674e-07H6.3199L1.0399 15.072H-9.76622e-05Z" fill="var(--color-secondary)" fill-opacity="0.6"></path>
                    </svg>
                </Breadcrumbs>
            </div>

            <section class="pt-8 md:pt-10">
                <h1 class="font-heading text-5xl mb-10">{contacts.pageTitle}</h1>

                <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
                    <Card class="bg-white py-5 min-h-50 relative">
                        <CardHeader class="border-b pb-4 border-[#2719071A]">
                            <CardTitle class="text-2xl">{contacts.addressLabel}</CardTitle>
                        </CardHeader>
                        <CardContent class="mt-auto">
                            <p class="whitespace-pre-line">{contacts.address}</p>
                        </CardContent>
                        <DecorImage class="absolute top-0 right-0" />
                    </Card>
                    <Card class="bg-white py-5 min-h-50 relative">
                        <CardHeader class="border-b pb-4 border-[#2719071A]">
                            <CardTitle class="text-2xl">{contacts.phoneLabel}</CardTitle>
                        </CardHeader>
                        <CardContent class="mt-auto">
                            <a href={phoneHref} class="text-xl font-semibold hover:text-primary transition-colors">{contacts.phoneDisplay}</a>
                        </CardContent>
                        <DecorImage class="absolute top-0 right-0" />
                    </Card>
                    <Card class="bg-white py-5 min-h-50 relative">
                        <CardHeader class="border-b pb-4 border-[#2719071A]">
                            <CardTitle class="text-2xl">{contacts.emailLabel}</CardTitle>
                        </CardHeader>
                        <CardContent class="mt-auto">
                            <a href={emailHref} class="break-all hover:text-primary transition-colors">{contacts.email}</a>
                        </CardContent>
                        <DecorImage class="absolute top-0 right-0" />
                    </Card>
                </div>
            </section>
        </div>
    </div>
</Layout>
