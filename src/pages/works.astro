---
import Layout from '@/layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import { Breadcrumbs } from 'astro-breadcrumbs'
import 'astro-breadcrumbs/breadcrumbs.css'

const items = await getCollection('gallery')

const crumbs = [{ text: 'Главная', href: '/' }, { text: 'Галерея работ' }]

const getPhotoCountLabel = (count: number) => {
  const mod10 = count % 10
  const mod100 = count % 100

  if (mod100 >= 11 && mod100 <= 14) {
    return `${count} фотографий`
  }

  if (mod10 === 1) {
    return `${count} фотография`
  }

  if (mod10 >= 2 && mod10 <= 4) {
    return `${count} фотографии`
  }

  return `${count} фотографий`
}

const getCardClass = (index: number) => {
  const pattern = [
    'lg:col-span-6 lg:row-span-2',
    'lg:col-span-3',
    'lg:col-span-3',
    'lg:col-span-3',
    'lg:col-span-3',
    'lg:col-span-6 lg:row-span-2 lg:col-start-7',
    'lg:col-span-3',
    'lg:col-span-3',
  ]

  return pattern[index % pattern.length]
}
---

<Layout>
  <div class="bg-[#F6F6F6] py-30 md:pt-50 md:pb-20">
    <div class="container">
      <div class="text-secondary pt-6">
        <Breadcrumbs crumbs={crumbs}>
          <svg slot="index" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g clip-path="url(#clip0_81_360)">
              <path
                d="M18.3333 4.77V1.66666C18.3333 1.20666 17.9608 0.83333 17.5 0.83333C17.0392 0.83333 16.6667 1.20666 16.6667 1.66666V3.63833L12.3308 0.712496C10.915 -0.242504 9.085 -0.242504 7.66917 0.712496L1.83583 4.64916C0.686667 5.425 0 6.71583 0 8.10333V15.8333C0 18.1308 1.86917 20 4.16667 20H5.83333C6.29417 20 6.66667 19.6267 6.66667 19.1667V11.6667C6.66667 11.2075 7.04 10.8333 7.5 10.8333H12.5C12.96 10.8333 13.3333 11.2075 13.3333 11.6667V19.1667C13.3333 19.6267 13.7058 20 14.1667 20H15.8333C18.1308 20 20 18.1308 20 15.8333V8.10333C20 6.78583 19.38 5.555 18.3333 4.77Z"
                fill="var(--color-secondary)"
                fill-opacity="0.8"></path>
            </g>
            <defs>
              <clipPath id="clip0_81_360">
                <rect width="20" height="20" fill="var(--color-secondary)"></rect>
              </clipPath>
            </defs>
          </svg>
          <svg slot="separator" width="7" height="16" viewBox="0 0 7 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M-9.76622e-05 15.072L5.2799 -9.53674e-07H6.3199L1.0399 15.072H-9.76622e-05Z" fill="var(--color-secondary)" fill-opacity="0.6"></path>
          </svg>
        </Breadcrumbs>
      </div>

      <section class="pt-8 md:pt-10">
        <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
          <h1 class="font-heading text-4xl md:text-5xl">Галерея работ</h1>
          <p class="text-secondary/70">{getPhotoCountLabel(items.length)}</p>
        </div>

        <ul id="works-gallery" class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-12">
          {
            items.map((item, index) => {
              const cardClass = getCardClass(index)
              const isLargeCard = cardClass.includes('row-span')

              return (
                <li class={cardClass}>
                  <a
                    href={item.data.image.src}
                    class="group block h-full overflow-hidden rounded-2xl"
                    data-pswp-width={item.data.image.width}
                    data-pswp-height={item.data.image.height}
                    aria-label={item.data.alt}>
                    <Image
                      src={item.data.image}
                      alt={item.data.alt}
                      class:list={[
                        'h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]',
                        isLargeCard ? 'aspect-16/11' : 'aspect-16/10',
                      ]}
                    />
                  </a>
                </li>
              )
            })
          }
        </ul>
      </section>
    </div>
  </div>
</Layout>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox'
  import 'photoswipe/style.css'

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#works-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
  })

  lightbox.init()
</script>
